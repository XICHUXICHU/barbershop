generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant root ───

model Barbershop {
  id        String   @id @default(uuid())
  ownerId   String   @default("") @map("owner_id")
  name      String
  slug      String   @unique
  phone     String
  address   String
  logoUrl   String?  @map("logo_url")
  coverUrl  String?  @map("cover_url")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  barbers      Barber[]
  services     Service[]
  appointments Appointment[]
  schedules    BarbershopSchedule[]

  @@map("barbershops")
}

model Barber {
  id           String   @id @default(uuid())
  barbershopId String   @map("barbershop_id")
  name         String
  avatarUrl    String?  @map("avatar_url")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([barbershopId])
  @@map("barbers")
}

model Service {
  id              String   @id @default(uuid())
  barbershopId    String   @map("barbershop_id")
  name            String
  description     String?
  imageUrl        String?  @map("image_url")
  durationMinutes Int      @map("duration_minutes")
  priceAmount     Int      @map("price_amount") // stored in cents
  priceCurrency   String   @default("USD") @map("price_currency")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  barbershop   Barbershop    @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([barbershopId])
  @@map("services")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String
  email     String?
  createdAt DateTime @default(now()) @map("created_at")

  appointments Appointment[]

  @@unique([phone])
  @@map("customers")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

model Appointment {
  id           String            @id @default(uuid())
  barbershopId String            @map("barbershop_id")
  barberId     String            @map("barber_id")
  serviceId    String            @map("service_id")
  customerId   String            @map("customer_id")
  date         DateTime          @db.Date
  startTime    String            @map("start_time") // HH:mm
  endTime      String            @map("end_time")   // HH:mm
  status       AppointmentStatus @default(PENDING)
  notes        String?
  createdAt    DateTime          @default(now()) @map("created_at")

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)
  barber     Barber     @relation(fields: [barberId], references: [id])
  service    Service    @relation(fields: [serviceId], references: [id])
  customer   Customer   @relation(fields: [customerId], references: [id])

  @@index([barbershopId, date])
  @@index([barberId, date])
  @@map("appointments")
}

model BarbershopSchedule {
  id           String @id @default(uuid())
  barbershopId String @map("barbershop_id")
  dayOfWeek    Int    @map("day_of_week") // 0=Sunday … 6=Saturday
  openTime     String @map("open_time")   // HH:mm
  closeTime    String @map("close_time")  // HH:mm
  isOpen       Boolean @default(true) @map("is_open")

  barbershop Barbershop @relation(fields: [barbershopId], references: [id], onDelete: Cascade)

  @@unique([barbershopId, dayOfWeek])
  @@map("barbershop_schedules")
}
